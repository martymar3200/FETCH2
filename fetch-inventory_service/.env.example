# FETCH2 Inventory Service Configuration
# Copy this file to .env and customize

# REQUIRED: Secret key for JWT signing
# Generate a new one for production: openssl rand -hex 32
SECRET_KEY=local-dev-secret-key-change-this-in-production

# App Environment settings
APP_ENVIRONMENT=local

# RECOMMENDED for local development:
DATABASE_URL=postgresql://postgres:postgres@inventory-database:5432/inventory_service
